
generator client {
  provider = "prisma-client-js"
}


datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

 
model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  roles     UserRole[]
}


model Order {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  status    Int?
  amount    Float?

  @@map("orders")
}

model Menu {
  id    Int     @id @default(autoincrement())
  name String
  icon  String
  url   String?
  parentId Int?
  order Int     @default(0) // 用于排序
}

model Nav {
  id          Int     @id @default(autoincrement())
  title       String
  icon        String?
  color       String?
  path        String?
  order_index Int?

  @@map("nav")
}


model dashboard_order {
  id          Int     @id @default(autoincrement())
  title       String
  unit        String
  unit_color  String?
  value       Int?
  sub_title   String?
  sub_value   String?
  order_index Int?

  @@map("dashboard_order")
}

model dashboard_goods {
  id     Int    @id @default(autoincrement())
  title  String
  status Int?
  stock  Int?

  @@map("dashboard_goods")
}

model dashboard_orders {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  title     String?
  status    Int?
  amount    Float?

  @@map("dashboard_orders")
}


model Role {
  id    Int    @id @default(autoincrement())
  roleName String
  roleKey String  @unique

  users UserRole[]
  permissions RolePermission[]
}

model Permission {
  id          Int    @id @default(autoincrement())
  pName        String
  pCode        String  @unique

  roles RolePermission[]
}


model UserRole {
  userId Int
  roleId Int
  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])
  @@id([userId, roleId])
}


model RolePermission {
  roleId Int
  permissionId Int
  role Role @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])
  @@id([roleId, permissionId])
}